  <div class="product-detail-title">
    <a href="https://www.decathlon.co.uk/sports/basketball/basketball-shoes">
      <h1>Basketball Shoes</h1>
    </a>
    <img src="/assets/images/product-name-logo.svg" class="dots-logo" alt="" width="16" height="16">
  </div>

{% include 'partials/carousel.liquid' %}

<section class="product-info">
  <p class="brand-name">{{ product.brand }}</p>
  <h2 class="product-name">{{ product.title }}</h2>

  <div class="review-rating">
    <label for="reviews" class="visually-hidden">Reviews:</label>
      <meter id="reviews" min="1" max="5" value="50"></meter>
      <span class="rating_count"> 4 reviews</span>
  </div>

  <p>{{ product.summary }}</p>

  <p class="product-id">ID {{ product.id }}</p>
</section>

{% comment %} SIZE GUIDE POPOVER = WONT HAVE {% endcomment %}
<button popovertarget="size-guide">Size guide</button>
<p popover id="size-guide">Size guide</p>

<form action="/cart/add" method="post">
  <input type="hidden" name="product_id" value="{{ product.id }}">

  <div class="select-wrapper">
    <label for="size">Size</label>
    <select class="select" id="size" name="size">
      <option value="" disabled selected hidden>Select</option>
      {% for size in product.sizes %}
        {% if size.available %}
          <option value="EU {{ size.size }}">EU {{ size.size }}</option>
        {% else %}
          <option value="EU {{ size.size }}" disabled>EU {{ size.size }} - Sold out</option>
        {% endif %}
      {% endfor %}
    </select>
  </div>

  <div class="input-wrapper">
    <button class="minus" type="button">-</button>
    <label for="quantity">Quantity</label>
    <input type="number" value="1" class="quantity" id="quantity" name="quantity" min="1">
    <button class="plus" type="button">+</button>
  </div>

  <p>${{ product.price }}</p>

  <button type="submit" class="add-to-cart-button">Add to basket</button>
</form>